# Root example env. Copy to .env for docker compose, and copy the per-app
# .env.example files into each app directory for local `pnpm dev`.

# --- PostgreSQL (docker compose) ---
POSTGRES_USER=signbridge
POSTGRES_PASSWORD=signbridge
POSTGRES_DB=signbridge

# --- API ---
DATABASE_URL=postgresql://signbridge:signbridge@localhost:5432/signbridge?schema=public
PORT=4000
CORS_ORIGIN=http://localhost:3000

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:4000
