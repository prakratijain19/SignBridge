# API service configuration
NODE_ENV=development
PORT=4000

# Comma-separated list of origins allowed by CORS
CORS_ORIGIN=http://localhost:3000

# PostgreSQL connection string used by Prisma
DATABASE_URL=postgresql://signbridge:signbridge@localhost:5432/signbridge?schema=public

# --- Authentication ---
# Secrets used to sign JWTs. REQUIRED in production (the API refuses to boot
# without them); insecure fallbacks are used in development if unset.
JWT_ACCESS_SECRET=dev-only-access-secret-change-me
JWT_REFRESH_SECRET=dev-only-refresh-secret-change-me
# Access-token lifetime (any value the `jsonwebtoken` library accepts, e.g. 15m).
ACCESS_TOKEN_TTL=15m
# Refresh-token lifetime in days.
REFRESH_TOKEN_TTL_DAYS=7

# --- Translation (Phase 7) ---
# Provider: "google-free" (default, free & keyless), "bhashini", or "identity"
# (passthrough). Leave unset to use google-free, which needs no configuration.
# TRANSLATION_PROVIDER=google-free
# Bhashini (AI4Bharat) credentials — optional; the API boots without them and
# falls back to identity/passthrough translation. Get these from bhashini.gov.in.
BHASHINI_USER_ID=
BHASHINI_API_KEY=
# Pipeline id for the translation pipeline config call.
BHASHINI_PIPELINE_ID=64392f96daac500b55c543cd

# --- Video calling (Phase 9) ---
# Public STUN is always used. TURN is optional and only needed for calls between
# devices on different networks; same-network/localhost works without it.
# TURN_URL=turn:turn.example.com:3478
# TURN_USERNAME=
# TURN_CREDENTIAL=
