// SignBridge database schema.
//
// Phase 1 establishes only the foundational models needed to prove the
// database wiring end-to-end. Authentication fields, conversation history,
// sign vocabulary, and learning-progress models are introduced in later
// phases (2, 4, 5, 11) so each migration maps cleanly to a delivered feature.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DEAF_USER
  HEARING_USER
  LEARNER
  ADMIN
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  passwordHash  String
  role          Role           @default(HEARING_USER)
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}
